# Telegram
API_ID=your_api_id
API_HASH=your_api_hash
SESSION_NAME=userbot_session

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key
AI_MODEL=anthropic/claude-3.5-sonnet
AI_TEMPERATURE=0.85
MAX_TOKENS=120

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=userbot

# Behavior
REPLY_PROBABILITY=0.12
MIN_REPLY_DELAY=8
MAX_REPLY_DELAY=45
TYPING_SIMULATION=true
MAX_REPLIES_PER_HOUR=3

# Safety
FLOOD_WAIT_MAX=3600
ENGAGEMENT_CAP_DAILY=25
MESSAGE_MAX_LENGTH=250
